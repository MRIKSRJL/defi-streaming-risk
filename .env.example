# Polygon WebSocket (Alchemy / Infura / other)
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Aave V3 Pool on Polygon PoS (canonical deployment; override if needed)
AAVE_V3_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD

# Redpanda / Kafka (local docker-compose default)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topic for normalized raw Aave events
AAVE_RAW_EVENTS_TOPIC=aave_raw_events

# Optional: topic bootstrap script
TOPICS_CONFIG_PATH=configs/topics.yaml

# Logging
LOG_LEVEL=INFO
